# Build artifacts
/target

# Local runtime data (SQLite DB, uploads, job metadata)
data*

# Local Codex CLI workspace
.codex
.claude
# Generated patch files
*.patch

# Frontend dependencies
/frontend/node_modules

# Local sensitive deployment config — NEVER commit these.
# They contain real server URLs, tokens, and host paths. If a token was ever
# committed or exposed, rotate WEBCODEX_TOKEN immediately.
/agent.toml
/projects.d/
/*.local.toml
/webcodex.env

# Generated documentation output (explicit rules, so docs/ stays tracked).
/docs-generated/
/docs-tmp/
/site/
