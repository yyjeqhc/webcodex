{
  "openapi": "3.1.0",
  "info": {
    "title": "Private Drop API",
    "version": "0.2.0",
    "description": "A self-hosted private long-text/file drop box API with Codex-like Project API for GPT Actions integration."
  },
  "servers": [{"url": "http://localhost:8080", "description": "Public server; runtime output uses DROP_PUBLIC_URL when set"}],
  "components": {
    "securitySchemes": {
      "bearerAuth": {"type": "http", "scheme": "bearer", "bearerFormat": "JWT"}
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {"status": {"type": "string"}, "version": {"type": "string"}},
        "required": ["status", "version"]
      },
      "Channel": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "display_name": {"type": "string"},
          "message_count": {"type": "integer"}
        },
        "required": ["name", "display_name", "message_count"]
      },
      "Message": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "channel": {"type": "string"},
          "kind": {"type": "string", "enum": ["text", "file"]},
          "title": {"type": "string", "nullable": true},
          "text": {"type": "string", "nullable": true},
          "file_name": {"type": "string", "nullable": true},
          "file_path": {"type": "string", "nullable": true},
          "file_size": {"type": "integer", "nullable": true},
          "mime_type": {"type": "string", "nullable": true},
          "created_at": {"type": "integer"},
          "expires_at": {"type": "integer", "nullable": true}
        },
        "required": ["id", "channel", "kind", "created_at"]
      },
      "CreateMessageRequest": {
        "type": "object",
        "properties": {
          "channel": {"type": "string"},
          "title": {"type": "string"},
          "text": {"type": "string"}
        },
        "required": ["channel", "text"]
      },
      "MessageListResponse": {
        "type": "object",
        "properties": {
          "messages": {"type": "array", "items": {"$ref": "#/components/schemas/Message"}},
          "total": {"type": "integer"},
          "has_more": {"type": "boolean"}
        },
        "required": ["messages", "total", "has_more"]
      },
      "ContextRequest": {
        "type": "object",
        "properties": {
          "project": {"type": "string", "description": "Project name from whitelist"},
          "mode": {"type": "string", "enum": ["overview", "tree", "search", "read_file", "git_status", "git_diff"], "description": "Context retrieval mode"},
          "path": {"type": "string", "description": "File path (for read_file mode)"},
          "query": {"type": "string", "description": "Search query (for search mode)"},
          "start_line": {"type": "integer", "default": 1, "description": "Start line for read_file (1-based)"},
          "limit": {"type": "integer", "default": 200, "description": "Max lines/items to return"}
        },
        "required": ["project", "mode"]
      },
      "ContextResponse": {
        "type": "object",
        "properties": {
          "success": {"type": "boolean"},
          "project": {"type": "string"},
          "mode": {"type": "string"},
          "content": {"type": "string", "nullable": true, "description": "Text content (for overview, read_file, git_status, git_diff)"},
          "items": {"type": "array", "items": {"type": "string"}, "nullable": true, "description": "List items (for tree, search)"},
          "truncated": {"type": "boolean"},
          "error": {"type": "string", "nullable": true}
        },
        "required": ["success", "project", "mode", "truncated"]
      },
      "ContextBatchItem": {
        "type": "object",
        "properties": {
          "mode": {"type": "string", "enum": ["overview", "tree", "search", "read_file", "git_status", "git_diff"]},
          "path": {"type": "string", "description": "File path for read_file mode"},
          "query": {"type": "string", "description": "Search query for search mode"},
          "start_line": {"type": "integer", "default": 1},
          "limit": {"type": "integer", "default": 200}
        },
        "required": ["mode"]
      },
      "ContextBatchRequest": {
        "type": "object",
        "properties": {
          "project": {"type": "string", "description": "Project name from whitelist"},
          "requests": {"type": "array", "minItems": 1, "maxItems": 20, "items": {"$ref": "#/components/schemas/ContextBatchItem"}}
        },
        "required": ["project", "requests"]
      },
      "ContextBatchResponse": {
        "type": "object",
        "properties": {
          "success": {"type": "boolean"},
          "project": {"type": "string"},
          "results": {"type": "array", "items": {"$ref": "#/components/schemas/ContextResponse"}},
          "duration_ms": {"type": "integer"},
          "ssh_calls": {"type": "integer"},
          "error": {"type": "string", "nullable": true}
        },
        "required": ["success", "project", "results", "duration_ms", "ssh_calls"]
      },
      "PatchRequest": {
        "type": "object",
        "properties": {
          "project": {"type": "string", "description": "Project name from whitelist"},
          "patch": {"type": "string", "description": "Unified diff patch content"},
          "reason": {"type": "string", "description": "Optional explanation for the patch"}
        },
        "required": ["project", "patch"]
      },
      "PatchResponse": {
        "type": "object",
        "properties": {
          "success": {"type": "boolean"},
          "changed_files": {"type": "array", "items": {"type": "string"}, "nullable": true},
          "stdout": {"type": "string", "nullable": true},
          "stderr": {"type": "string", "nullable": true},
          "error": {"type": "string", "nullable": true}
        },
        "required": ["success"]
      },
      "ReplaceTextEdit": {
        "type": "object",
        "description": "Replace occurrences of old_text with new_text in an existing file. occurrence is 1-based; omit it when old_text appears exactly once.",
        "properties": {
          "type": {"type": "string", "enum": ["replace_text"]},
          "path": {"type": "string", "description": "Relative file path within the project"},
          "old_text": {"type": "string", "description": "Exact text to find (must appear at least once)"},
          "new_text": {"type": "string", "description": "Replacement text"},
          "occurrence": {"type": "integer", "minimum": 1, "description": "1-based occurrence index; required when old_text matches more than once"}
        },
        "required": ["type", "path", "old_text", "new_text"]
      },
      "ReplaceRangeEdit": {
        "type": "object",
        "description": "Replace a 1-based inclusive line range [start_line, end_line] with new_text.",
        "properties": {
          "type": {"type": "string", "enum": ["replace_range"]},
          "path": {"type": "string", "description": "Relative file path within the project"},
          "start_line": {"type": "integer", "minimum": 1, "description": "First line to replace (1-based, inclusive)"},
          "end_line": {"type": "integer", "minimum": 1, "description": "Last line to replace (1-based, inclusive)"},
          "new_text": {"type": "string", "description": "Replacement text for the line range"}
        },
        "required": ["type", "path", "start_line", "end_line", "new_text"]
      },
      "AppendFileEdit": {
        "type": "object",
        "description": "Append text to the end of an existing file.",
        "properties": {
          "type": {"type": "string", "enum": ["append_file"]},
          "path": {"type": "string", "description": "Relative file path within the project"},
          "text": {"type": "string", "description": "Text to append"}
        },
        "required": ["type", "path", "text"]
      },
      "CreateFileEdit": {
        "type": "object",
        "description": "Create a new file. Fails if the file already exists.",
        "properties": {
          "type": {"type": "string", "enum": ["create_file"]},
          "path": {"type": "string", "description": "Relative file path within the project"},
          "content": {"type": "string", "description": "Initial file content"}
        },
        "required": ["type", "path", "content"]
      },
      "WriteFileEdit": {
        "type": "object",
        "description": "Write content to a file. Not recommended for small changes — prefer replace_text, replace_range, or create_file instead. Set allow_overwrite=true to overwrite existing files.",
        "properties": {
          "type": {"type": "string", "enum": ["write_file"]},
          "path": {"type": "string", "description": "Relative file path within the project"},
          "content": {"type": "string", "description": "Full file content to write"},
          "allow_overwrite": {"type": "boolean", "default": false, "description": "Must be true to overwrite an existing file"}
        },
        "required": ["type", "path", "content"]
      },
      "EditRequest": {
        "type": "object",
        "properties": {
          "project": {"type": "string", "description": "Project name from whitelist"},
          "reason": {"type": "string"},
          "dry_run": {"type": "boolean", "default": false, "description": "If true, returns a diff but does not write files"},
          "edits": {
            "type": "array",
            "items": {
              "oneOf": [
                {"$ref": "#/components/schemas/ReplaceTextEdit"},
                {"$ref": "#/components/schemas/ReplaceRangeEdit"},
                {"$ref": "#/components/schemas/AppendFileEdit"},
                {"$ref": "#/components/schemas/CreateFileEdit"},
                {"$ref": "#/components/schemas/WriteFileEdit"}
              ],
              "discriminator": {"propertyName": "type", "mapping": {"replace_text": "#/components/schemas/ReplaceTextEdit", "replace_range": "#/components/schemas/ReplaceRangeEdit", "append_file": "#/components/schemas/AppendFileEdit", "create_file": "#/components/schemas/CreateFileEdit", "write_file": "#/components/schemas/WriteFileEdit"}}
            }
          }
        },
        "required": ["project", "edits"]
      },
      "EditResponse": {
        "type": "object",
        "properties": {
          "success": {"type": "boolean"},
          "changed_files": {"type": "array", "items": {"type": "string"}},
          "diff": {"type": "string"},
          "warnings": {"type": "array", "items": {"type": "string"}},
          "error": {"type": "string", "nullable": true}
        },
        "required": ["success", "changed_files", "diff", "warnings"]
      },
      "CheckRequest": {
        "type": "object",
        "properties": {
          "project": {"type": "string", "description": "Project name from whitelist"},
          "suite": {"type": "string", "enum": ["fmt", "test", "build", "e2e", "full"], "description": "Check suite to run"}
        },
        "required": ["project", "suite"]
      },
      "CheckResponse": {
        "type": "object",
        "properties": {
          "success": {"type": "boolean"},
          "suite": {"type": "string", "nullable": true},
          "exit_code": {"type": "integer", "nullable": true},
          "duration_ms": {"type": "integer", "nullable": true},
          "stdout_tail": {"type": "string", "nullable": true, "description": "Last part of stdout (max 50000 chars)"},
          "stderr_tail": {"type": "string", "nullable": true, "description": "Last part of stderr (max 50000 chars)"},
          "truncated": {"type": "boolean"},
          "error": {"type": "string", "nullable": true}
        },
        "required": ["success", "truncated"]
      },
      "ReportRequest": {
        "type": "object",
        "properties": {
          "project": {"type": "string", "description": "Project name from whitelist"},
          "status": {"type": "string", "enum": ["completed", "failed", "blocked"], "description": "Operation status"},
          "title": {"type": "string", "description": "Report title"},
          "summary": {"type": "string", "description": "Detailed summary"},
          "channel": {"type": "string", "default": "omo", "description": "Channel to post message to"}
        },
        "required": ["project", "status", "title", "summary"]
      },
      "ReportResponse": {
        "type": "object",
        "properties": {
          "success": {"type": "boolean"},
          "report_id": {"type": "string", "nullable": true},
          "message_id": {"type": "string", "nullable": true},
          "path": {"type": "string", "nullable": true},
          "error": {"type": "string", "nullable": true}
        },
        "required": ["success"]
      }
    }
  },
  "security": [{"bearerAuth": []}],
  "paths": {
    "/api/health": {
      "get": {
        "operationId": "healthCheck",
        "summary": "Health check",
        "tags": ["health"],
        "security": [],
        "responses": {
          "200": {"description": "Health status", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HealthResponse"}}}}
        }
      }
    },
    "/api/channels": {
      "get": {
        "operationId": "listChannels",
        "summary": "List all channels",
        "tags": ["channels"],
        "responses": {
          "200": {"description": "List of channels", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/Channel"}}}}}
        }
      }
    },
    "/api/messages": {
      "get": {
        "operationId": "listMessages",
        "summary": "List messages",
        "tags": ["messages"],
        "parameters": [
          {"name": "channel", "in": "query", "schema": {"type": "string"}, "description": "Filter by channel"},
          {"name": "limit", "in": "query", "schema": {"type": "integer", "default": 50, "maximum": 200}, "description": "Max messages"},
          {"name": "before", "in": "query", "schema": {"type": "integer"}, "description": "Before timestamp"}
        ],
        "responses": {
          "200": {"description": "List of messages", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/MessageListResponse"}}}}
        }
      },
      "post": {
        "operationId": "createMessage",
        "summary": "Create a text message",
        "tags": ["messages"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CreateMessageRequest"}}}
        },
        "responses": {
          "200": {"description": "Created message", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Message"}}}},
          "400": {"description": "Bad request"},
          "413": {"description": "Payload too large"}
        }
      }
    },
    "/api/messages/{id}": {
      "get": {
        "operationId": "getMessage",
        "summary": "Get a message by ID",
        "tags": ["messages"],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {"description": "Message details", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Message"}}}},
          "404": {"description": "Not found"}
        }
      },
      "delete": {
        "operationId": "deleteMessage",
        "summary": "Delete a message",
        "tags": ["messages"],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {"description": "Deleted"},
          "404": {"description": "Not found"}
        }
      }
    },
    "/api/files": {
      "post": {
        "operationId": "uploadFile",
        "summary": "Upload a file",
        "tags": ["files"],
        "parameters": [{"name": "channel", "in": "query", "schema": {"type": "string", "default": "files"}}],
        "requestBody": {
          "required": true,
          "content": {"multipart/form-data": {"schema": {"type": "object", "properties": {"file": {"type": "string", "format": "binary"}}, "required": ["file"]}}}
        },
        "responses": {
          "200": {"description": "File uploaded", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Message"}}}},
          "413": {"description": "File too large"}
        }
      }
    },
    "/api/files/{id}": {
      "get": {
        "operationId": "downloadFile",
        "summary": "Download a file",
        "tags": ["files"],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {"description": "File content"},
          "404": {"description": "Not found"}
        }
      }
    },
    "/api/codex/context": {
      "post": {
        "operationId": "getProjectContext",
        "summary": "Read-only project observation",
        "description": "Observe a whitelisted project: get overview, file tree, search, read files, git status/diff.",
        "tags": ["codex"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ContextRequest"}}}
        },
        "responses": {
          "200": {"description": "Context response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ContextResponse"}}}},
          "400": {"description": "Bad request"}
        }
      }
    },
    "/api/codex/context_batch": {
      "post": {
        "operationId": "getProjectContextBatch",
        "summary": "Run multiple project context observations in one request",
        "description": "Batch up to 20 context observations for one whitelisted project. Useful for reducing GPT Action round trips; SSH projects also benefit from ControlMaster reuse.",
        "tags": ["codex"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ContextBatchRequest"}}}
        },
        "responses": {
          "200": {"description": "Batch context response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ContextBatchResponse"}}}},
          "400": {"description": "Bad request"}
        }
      }
    },
    "/api/codex/apply_patch": {
      "post": {
        "operationId": "applyProjectPatch",
        "summary": "Apply a unified diff patch",
        "description": "Apply a unified diff patch to a whitelisted project. Only modifies project files, blocks sensitive paths.",
        "tags": ["codex"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PatchRequest"}}}
        },
        "responses": {
          "200": {"description": "Patch result", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PatchResponse"}}}},
          "400": {"description": "Bad request"},
          "403": {"description": "Patch not allowed for this project"}
        }
      }
    },
    "/api/codex/edit": {
      "post": {
        "operationId": "applyProjectEdit",
        "summary": "Apply safe structured file edits",
        "description": "Apply replace_text, replace_range, append_file, create_file, or guarded write_file edits to a whitelisted project. Returns a diff and supports dry_run.",
        "tags": ["codex"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EditRequest"}}}
        },
        "responses": {
          "200": {"description": "Edit result", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EditResponse"}}}},
          "400": {"description": "Bad request"},
          "403": {"description": "Edit not allowed or unsafe path"},
          "413": {"description": "Edit payload too large"}
        }
      }
    },
    "/api/codex/check": {
      "post": {
        "operationId": "runProjectCheck",
        "summary": "Run a project check suite",
        "description": "Run a pre-configured check command (fmt, test, build, e2e, full) on a whitelisted project.",
        "tags": ["codex"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CheckRequest"}}}
        },
        "responses": {
          "200": {"description": "Check result", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CheckResponse"}}}},
          "400": {"description": "Bad request"},
          "403": {"description": "Check suite not allowed"}
        }
      }
    },
    "/api/codex/report": {
      "post": {
        "operationId": "writeProjectReport",
        "summary": "Write an operation report",
        "description": "Write a GPT/Codex operation report to local storage and post a summary message to a channel.",
        "tags": ["codex"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ReportRequest"}}}
        },
        "responses": {
          "200": {"description": "Report result", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ReportResponse"}}}},
          "400": {"description": "Bad request"}
        }
      }
    }
  }
}
