# Private Drop server environment file.
#
# Copy to /etc/private-drop/private-drop.env and edit:
#   sudo install -d -m 0755 -o root -g root /etc/private-drop
#   sudo install -m 0600 deploy/private-drop.env.example /etc/private-drop/private-drop.env
#   sudo $EDITOR /etc/private-drop/private-drop.env
#
# This file is loaded by the systemd unit via EnvironmentFile=. Keep it
# chmod 0600 and owned by root — it contains the bearer token.
#
# Syntax: KEY=value (one per line). # comments and `export ` prefix allowed.
# Quoted values have their surrounding quotes stripped.

# REQUIRED (production): long random bearer token for all protected endpoints
# and the agent WebSocket/polling handshake. NEVER leave this unset in
# production — the server runs without auth when it is empty.
DROP_TOKEN=REPLACE_WITH_LONG_RANDOM_SECRET

# Bind address. Behind a reverse proxy, keep 127.0.0.1 so only the proxy is
# publicly reachable.
DROP_ADDR=127.0.0.1:8080

# Persistent runtime data dir: SQLite DB (drop.db), uploads, job metadata.
DROP_DATA=/var/lib/private-drop

# REQUIRED (production): the public HTTPS URL. Used as servers[0].url in
# /openapi.json so ChatGPT imports actions against the right host.
DROP_PUBLIC_URL=https://drop.example.com

# Optional: explicit path to an env file (the server also auto-loads
# ./private-drop.env, /opt/private-drop/private-drop.env, and
# /etc/private-drop/private-drop.env if present and DROP_ENV_FILE is unset).
# DROP_ENV_FILE=/etc/private-drop/private-drop.env

# Log level. info is a good default; debug is verbose.
RUST_LOG=info

# ---- Codex CLI (runs on the AGENT host, not the server) ----
# These are read by the agent process that spawns Codex. The server validates
# prompts and forwards run_codex to the owning agent. Set them on the agent
# host's environment or its systemd unit, not necessarily here.
# CODEX_BIN=codex
# CODEX_APPROVAL_MODE=full-auto
# CODEX_DEFAULT_TIMEOUT_SECS=3600
# CODEX_MAX_PROMPT_BYTES=100000
# CODEX_ALLOWED_EXTRA_ARGS=--verbose,--json,--no-color
