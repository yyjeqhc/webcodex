# Agent-side project file, intended to live under the agent's projects_dir.
#
# Copy to <projects_dir>/webcodex.toml (e.g.
# /etc/webcodex/projects.d/webcodex.toml) and edit the path.
#
# At registration the agent reports this to the server, which exposes it as the
# runtime id agent:<client_id>:webcodex. The server never needs the matching
# server-side [projects.webcodex] block — it is a zero-project-config relay.

id = "webcodex"
path = "/root/git/webcodex"
name = "WebCodex"
allow_patch = true
kind = "rust"
shell_profile = "rust"
description = "WebCodex Runtime repository"
