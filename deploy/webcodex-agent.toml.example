# Example config for webcodex-agent.
# Copy to /etc/webcodex/agent.toml and edit token/client_id/server_url.
# Prefer generating this file with: webcodex-cli agent init
# The compatibility command webcodex-agent init still works.

server_url = "https://webcodex.example.com"
token = "replace-with-agent-token"
client_id = "example-agent"
display_name = "Example Agent"
owner = "example-user"
transport = "auto"
poll_interval_ms = 1000
projects_dir = "/etc/webcodex/projects.d"

# Agent transport. New deployments should prefer auto transport with
# [quic] configured: the agent tries QUIC first, then WebSocket, then polling.
# Use transport = "quic" only when you want strict QUIC without fallback.
# QUIC is a custom WebCodex agent stream transport, NOT HTTP/3; the server
# listens directly on UDP 8443 when enabled, and Nginx does not need QUIC/HTTP/3
# support for GPT Actions or MCP. runtime_status/listAgents report the actual
# connected transport. See docs/AGENT_TRANSPORTS.md.
# transport = "quic"
# transport = "websocket"
# transport = "polling"
# transport = "auto"
# [quic]
# server_addr = "webcodex.example.com:8443"
# server_name = "webcodex.example.com"
# alpn = "webcodex-agent/1"
# connect_timeout_secs = 10
# keepalive_interval_secs = 20

# Shell profiles describe prepared development environments for projects.
# init_script is inline shell text, not a file path. runtime_status/listAgents
# do not expose profile env values or init_script text.
[shell]
default_profile = "rust"

[shell.profiles.rust]
description = "Rust development tools"
program = "sh"
args = ["-c"]

[shell.profiles.rust.env]
PATH = "/home/webcodex/.cargo/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
CARGO_HOME = "/home/webcodex/.cargo"
RUSTUP_HOME = "/home/webcodex/.rustup"

[shell.profiles.py-venv]
description = "Project-local Python virtual environment"
program = "bash"
args = ["-lc"]
init_script = '''
source .venv/bin/activate
'''

[shell.profiles.conda-ml]
description = "Conda ML environment"
program = "bash"
args = ["-lc"]
init_script = '''
source /opt/miniconda3/etc/profile.d/conda.sh
conda activate ml
'''

[capabilities]
file_read = true
file_write = true
git = true
shell = true
jobs = true
async_jobs = true
async_shell_jobs = true

[policy]
# Missing or empty allowed_roots defaults to $HOME.
# Explicit allowed_roots replaces that default. Leave it empty to use $HOME, or
# set a narrower workspace root for production hardening.
allow_raw_shell = true
allow_cwd_anywhere = false
# allowed_roots = []
# Example narrow root only; not the default:
# allowed_roots = ["/root/git"]
max_timeout_secs = 3600
max_output_bytes = 262144
