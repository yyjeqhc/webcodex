# WebCodex server environment file.
#
# Copy to /etc/webcodex/webcodex.env and edit:
#   sudo install -d -m 0755 -o root -g root /etc/webcodex
#   sudo install -m 0600 deploy/webcodex.env.example /etc/webcodex/webcodex.env
#   sudo $EDITOR /etc/webcodex/webcodex.env
#
# This file is loaded by the systemd unit via EnvironmentFile=. Keep it
# chmod 0600 and owned by root — it contains the bearer token.
#
# Syntax: KEY=value (one per line). # comments and `export ` prefix allowed.
# Quoted values have their surrounding quotes stripped.

# REQUIRED (production): long random bearer token for all protected endpoints
# and the agent WebSocket/polling handshake. NEVER leave this unset in
# production — the server runs without auth when it is empty.
WEBCODEX_TOKEN=REPLACE_WITH_LONG_RANDOM_SECRET

# Bind address. Behind a reverse proxy, keep 127.0.0.1 so only the proxy is
# publicly reachable.
WEBCODEX_ADDR=127.0.0.1:8080

# Persistent runtime data dir: SQLite DB (webcodex.db), uploads, job metadata.
WEBCODEX_DATA=/var/lib/webcodex

# REQUIRED (production): the public HTTPS URL. Used as servers[0].url in
# /openapi.json so ChatGPT imports actions against the right host.
WEBCODEX_PUBLIC_URL=https://webcodex.example.com

# Optional: explicit path to an env file (the server also auto-loads
# ./webcodex.env, /opt/webcodex/webcodex.env, and
# /etc/webcodex/webcodex.env if present and WEBCODEX_ENV_FILE is unset).
# WEBCODEX_ENV_FILE=/etc/webcodex/webcodex.env

# Log level. info is a good default; debug is verbose.
RUST_LOG=info

# Experimental: shrink selected GPT Action callRuntimeTool success payloads
# (notably start_coding_task) after execution. Default off — full responses.
# Does not change MCP, tools/list, OpenAPI schemas, tool execution, session
# ledger, or permission decisions.
# WEBCODEX_ACTION_COMPACT_RESPONSES=true

# ---- Codex CLI (external/local workflows only) ----
# WebCodex no longer exposes run_codex or legacy /api/codex/* routes.
# Run Codex outside WebCodex if you need Codex-specific workflows.
# The WebCodex runtime uses structured tools, agent-registered projects,
# bounded shell/job validation, and MCP/GPT Action tool calls.
# These values are reserved for external/local Codex workflows and are not used
# by the WebCodex runtime tool surface.
# CODEX_BIN=codex
# CODEX_APPROVAL_MODE=full-auto
# CODEX_DEFAULT_TIMEOUT_SECS=3600
# CODEX_MAX_PROMPT_BYTES=100000
# CODEX_ALLOWED_EXTRA_ARGS=--verbose,--json,--no-color
