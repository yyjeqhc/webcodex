# Example projects.toml for the WebCodex runtime.
#
# PROJECTS_CONFIG points here. Each project maps a stable id to a local path
# and an executor. `executor = "local"` runs on the server host;
# `executor = "agent"` queues work for a registered webcodex-agent
# (identified by `client_id`).

[projects.webcodex]
path = "/root/git/webcodex"
executor = "local"
allow_patch = true

[projects.remote-demo]
path = "/root/git/remote-demo"
executor = "agent"
client_id = "workstation-1"
allow_patch = true

# ---------------------------------------------------------------------------
# Legacy fields (parsed but not used by current runtime routes)
# ---------------------------------------------------------------------------
# The following fields are still deserialized for backwards compatibility, but
# no current runtime HTTP route invokes them. They are documented here only so
# existing config files keep loading:
#
#   allow_command_requests       - old command_request workflow (removed)
#   allow_raw_command_requests   - old trusted raw command workflow (removed)
#   checks / allowed_checks      - old runProjectCheck suite (removed)
#   commands                     - old named command map (removed)
#   hooks                        - old project_doctor / project_hook (removed)
#   default_apply_patch_backend  - old patch backend selector (unused)
#
# To run checks or long work, use the current runtime surface:
#   runCodexTask          POST /api/codex/run
#   getRuntimeJobStatus   POST /api/jobs/status
#   getRuntimeJobLog      POST /api/jobs/log
#   callRuntimeTool       POST /api/tools/call  (run_shell, run_job, ...)
