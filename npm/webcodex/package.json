{
  "name": "@yyjeqhc/webcodex",
  "version": "0.2.0",
  "description": "Thin npm installer/wrapper for WebCodex native binaries.",
  "license": "Apache-2.0",
  "bin": {
    "webcodex": "bin/webcodex.js",
    "webcodex-agent": "bin/webcodex-agent.js",
    "webcodex-cli": "bin/webcodex-cli.js"
  },
  "scripts": {
    "postinstall": "node install.js",
    "test": "node test/self-test.js",
    "pack:dry-run": "npm pack --dry-run",
    "smoke:local": "bash ../../scripts/npm_package_smoke.sh",
    "prepublishOnly": "node test/release-manifest-check.js"
  },
  "files": [
    "bin",
    "install.js",
    "manifest.json",
    "manifest.example.json",
    "README.md",
    "test",
    "vendor/.gitkeep"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "url": "git+https://github.com/yyjeqhc/webcodex.git"
  },
  "bugs": {
    "url": "https://github.com/yyjeqhc/webcodex/issues"
  },
  "homepage": "https://github.com/yyjeqhc/webcodex#readme"
}
