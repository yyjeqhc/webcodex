# Optional global SSH tuning for SSH executor projects.
# ControlMaster reuses SSH connections and reduces per-request handshake cost.
# [ssh]
# batch_mode = true
# connect_timeout_secs = 10
# control_master = true
# control_persist = "10m"
# control_path = "/tmp/private-drop-ssh-%C"
# server_alive_interval = 30
# server_alive_count_max = 3

# Local executor: commands run on the same machine as private-drop
[projects.private-drop]
path = "/root/git/private-drop"
allow_patch = true
# Optional: default patch backend for /api/codex/apply_patch when request.backend is omitted.
# Valid values: "builtin" (default, git apply) or "codex" (experimental Codex apply_patch executable).
# default_apply_patch_backend = "builtin"
allow_command_requests = true
allow_raw_command_requests = false
allowed_checks = ["fmt", "test", "build", "e2e", "full"]

[projects.private-drop.checks]
fmt = "cargo fmt --check"
test = "cargo test"
build = "cargo build --release"
e2e = "bash scripts/e2e_test.sh"
full = "cargo fmt --check && cargo test && cargo build --release && bash scripts/e2e_test.sh"

# Optional extra project-level commands for /api/codex/command.
# Requests can only choose one of these ids; they cannot provide arbitrary shell.
[projects.private-drop.commands]
clippy = "cargo clippy --all-targets -- -D warnings"
doc = "cargo doc --no-deps"

# SSH executor: commands run on a remote machine via SSH
# Use this when private-drop is deployed on a gateway (e.g., SG4) but
# the actual project lives on a different machine (reachable via Tailscale).
#
# Before using SSH executor, verify connectivity:
#   ssh msi 'cd /root/git/private-drop && cargo test'
#
# [projects.private-drop]
# executor = "ssh"
# host = "msi"
# Optional fallback endpoints. Legacy host remains the first endpoint when both are set.
# ssh_hosts = ["msi-rev4", "msi-rev6"]
# user = "root"
# path = "/root/git/private-drop"
# allow_patch = true
# default_apply_patch_backend = "builtin"
# allow_command_requests = true
# allow_raw_command_requests = false
# allowed_checks = ["fmt", "test", "build", "e2e"]
#
# [projects.private-drop.checks]
# fmt = "cargo fmt --check"
# test = "cargo test"
# build = "cargo build --release"
# e2e = "bash scripts/e2e_test.sh"
#
# [projects.private-drop.commands]
# clippy = "cargo clippy --all-targets -- -D warnings"
# doc = "cargo doc --no-deps"
